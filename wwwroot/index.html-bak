<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>The Curator | Hello World</title>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@700;800&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-highest": "#d9e4ea",
                    "primary-dim": "#4a5268",
                    "on-primary-fixed-variant": "#535b71",
                    "error-dim": "#4e0309",
                    "on-primary-fixed": "#373f54",
                    "on-primary": "#f7f7ff",
                    "surface-container-lowest": "#ffffff",
                    "on-error": "#fff7f6",
                    "surface-bright": "#f7f9fb",
                    "tertiary": "#625b77",
                    "secondary-fixed-dim": "#c7d5ed",
                    "inverse-surface": "#0b0f10",
                    "on-secondary": "#f8f8ff",
                    "on-error-container": "#752121",
                    "surface-container-low": "#f0f4f7",
                    "surface-tint": "#565e74",
                    "surface-variant": "#d9e4ea",
                    "surface": "#f7f9fb",
                    "primary-fixed": "#dae2fd",
                    "on-secondary-fixed": "#324053",
                    "secondary-container": "#d5e3fc",
                    "secondary-dim": "#465468",
                    "surface-dim": "#cfdce3",
                    "on-primary-container": "#4a5167",
                    "tertiary-container": "#dfd5f7",
                    "error-container": "#fe8983",
                    "surface-container-high": "#e1e9ee",
                    "primary": "#565e74",
                    "outline": "#717c82",
                    "tertiary-fixed-dim": "#d0c7e8",
                    "on-tertiary": "#fdf7ff",
                    "inverse-primary": "#dae2fd",
                    "error": "#9f403d",
                    "tertiary-fixed": "#dfd5f7",
                    "on-tertiary-fixed": "#3c3650",
                    "on-background": "#2a3439",
                    "tertiary-dim": "#564f6b",
                    "secondary-fixed": "#d5e3fc",
                    "on-tertiary-container": "#4f4964",
                    "primary-fixed-dim": "#ccd4ee",
                    "on-tertiary-fixed-variant": "#59526e",
                    "background": "#f7f9fb",
                    "primary-container": "#dae2fd",
                    "on-secondary-fixed-variant": "#4e5c71",
                    "inverse-on-surface": "#9a9d9f",
                    "outline-variant": "#a9b4b9",
                    "surface-container": "#e8eff3",
                    "on-surface": "#2a3439",
                    "on-surface-variant": "#566166",
                    "on-secondary-container": "#455367",
                    "secondary": "#526074"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        /* Custom Ambient Shadows per Design System */
        .ambient-shadow {
            box-shadow: 0px 4px 20px rgba(42, 52, 57, 0.04), 0px 12px 40px rgba(42, 52, 57, 0.06);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface font-body text-on-surface flex flex-col min-h-screen">
<!-- TopAppBar -->
<header class="bg-[#f7f9fb] dark:bg-slate-950 docked full-width top-0 z-50">
<div class="max-w-7xl mx-auto px-12 py-8 flex justify-between items-center w-full">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-[#565e74] dark:text-slate-300" data-icon="menu">menu</span>
<span class="text-2xl font-bold tracking-[-0.02em] text-[#2a3439] dark:text-white font-headline">The Curator</span>
</div>
<nav class="hidden md:flex items-center gap-8">
<a class="text-[#565e74] dark:text-white font-bold font-headline hover:text-[#2a3439] transition-colors duration-200" href="#">Journal</a>
<a class="text-[#565e74]/60 dark:text-slate-400 font-medium font-headline hover:text-[#2a3439] transition-colors duration-200" href="#">Archives</a>
<button class="bg-[#565e74] text-white px-6 py-2 rounded-xl font-headline font-bold text-sm hover:scale-95 duration-200">Contact</button>
</nav>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center px-6 py-12 relative overflow-hidden">
<!-- Background Decor (Subtle shifts in color temperature) -->
<div class="absolute top-0 left-0 w-full h-full -z-10 opacity-30 pointer-events-none">
<div class="absolute top-[-10%] right-[-5%] w-[400px] h-[400px] rounded-full bg-secondary-container blur-[100px]"></div>
<div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-primary-container blur-[100px]"></div>
</div>
<!-- The Hero Card (The "Silent Curator" Anchor) -->
<section class="max-w-2xl w-full">
<div class="bg-surface-container-lowest rounded-xl p-12 md:p-16 ambient-shadow text-center relative">
<!-- Editorial Scale Header -->
<h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface tracking-[-0.04em] mb-6">
                    Hello World
                </h1>
<!-- Clinical Clarity Body Text -->
<p class="font-body text-lg md:text-xl text-on-surface-variant max-w-md mx-auto leading-relaxed mb-10">
                    Welcome to a space of intentional design and atmospheric clarity. Every element here is curated to provide presence through absence.
                </p>
<!-- CTA with Glass & Gradient Rule -->
<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
<button class="bg-gradient-to-br from-primary to-primary-dim text-on-primary px-8 py-4 rounded-xl font-headline font-bold tracking-tight ambient-shadow hover:scale-95 transition-transform duration-200">
                        Begin Exploring
                    </button>
<button class="bg-transparent text-primary px-8 py-4 rounded-xl font-headline font-bold border border-outline-variant/15 hover:bg-surface-container-low transition-all duration-200">
                        Learn More
                    </button>
</div>
<!-- Decorative Asset -->
<div class="mt-12 opacity-80">
<img alt="Minimalist abstract" class="w-full h-48 object-cover rounded-md" data-alt="Close-up of clean white paper layers casting soft architectural shadows in a sunlit minimalist gallery setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDZ46idfYdbXgGXag-PnSjGBWkvgIhbZAEVwuKYeT_GjvrU3CCMfNiM3oN3dXD67VTLfkDM0ObCeahCW3Nd4NX5kqV2p8baCBr5sGYU93svDo7wNOPI74pw5pCdYLvkqUQDB_8V5tSRwXmiSjxJyNqA4D08cj0WHvLJzHHsylYiuLz-PVAX8HeXVBNgbroOJmUt7swFSl0bozLmeQ4MUerqeoVNmEdxGdz7D4vJRr79Hf-UOVUR4bcLWcrfAfG9qeZ_c7VQI6wWCWyK"/>
</div>
</div>
</section>
</main>
<!-- Footer -->
<footer class="bg-[#f7f9fb] dark:bg-slate-950 w-full py-16">
<div class="max-w-7xl mx-auto px-12 flex flex-col md:flex-row justify-between items-center gap-8">
<div class="flex flex-col items-center md:items-start gap-2">
<span class="text-lg font-bold text-[#565e74] font-headline">The Silent Curator</span>
<p class="font-['Inter'] text-sm tracking-wide text-[#565e74]/50 dark:text-slate-500">
                    © 2024 The Silent Curator. All rights reserved.
                </p>
</div>
<div class="flex gap-8">
<a class="font-['Inter'] text-sm tracking-wide text-[#565e74]/50 dark:text-slate-500 hover:text-[#565e74] dark:hover:text-slate-200 transition-all opacity-80" href="#">Privacy Policy</a>
<a class="font-['Inter'] text-sm tracking-wide text-[#565e74]/50 dark:text-slate-500 hover:text-[#565e74] dark:hover:text-slate-200 transition-all opacity-80" href="#">Terms of Service</a>
<a class="font-['Inter'] text-sm tracking-wide text-[#565e74] underline underline-offset-4 transition-all opacity-80" href="#">Journal</a>
</div>
</div>
</footer>
</body></html>